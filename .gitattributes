# Normalize line endings: LF in repo, CRLF on Windows checkout
* text=auto

# Force LF for scripts and config (never CRLF)
*.py        text eol=lf
*.jsx       text eol=lf
*.css       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.typ       text eol=lf
Dockerfile  text eol=lf

# Binary — never diff or normalize
*.pdf       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.sqlite    binary
