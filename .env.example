# ── Modèles LLM ──────────────────────────────────────────────────────────────
MODEL=qwen3:8b                          # fallback rétrocompat (remplacé par MATCHING_MODEL)
MATCHING_MODEL=qwen3:8b                 # modèle utilisé pour l'analyse de matching
GENERATION_MODEL=qwen3:14b             # modèle utilisé pour la génération du CV
OLLAMA_BASE_URL=http://host.docker.internal:11434  # URL Ollama (Linux: http://ollama:11434)

# ── Paramètres de retrieval ───────────────────────────────────────────────────
TOP_K=45                                # nombre de preuves récupérées par requête
MAX_EVIDENCE_FOR_LLM=60                # limite envoyée au LLM

# ── Chemins fichiers ─────────────────────────────────────────────────────────
CV_PATH=/app/data/cv_master.json
SEMANTIC_GRAPH_PATH=/app/data/semantic_graph.json
SQLITE_PATH=/app/storage/evidence.sqlite
HISTORY_DB_PATH=/app/storage/history.sqlite
OUTPUT_DIR=/app/outputs
CUSTOM_THEMES_DIR=/custom              # dossier des thèmes RenderCV personnalisés

# ── CORS ─────────────────────────────────────────────────────────────────────
# En prod, remplacer par l'URL publique de l'application
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
